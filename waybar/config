{
    "layer": "top",
    "position": "top",
    "height": 30,
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "mpris", "custom/weather", "custom/power"],

    "hyprland/workspaces": { "format": "{name}" },
    "hyprland/window": { "format": "{title}", "max-length": 40 },
    "clock": { "format": "󰃰 {:%d.%m.%Y %H:%M}" },
    "cpu": { "format": "󰍛 CPU: {usage}%" },
    "memory": { "format": "󰘚 RAM: {}%" },
    "mpris": { "format": "♪ {title}", "max-length": 20 },
    "custom/weather": {
        "exec": "curl -s 'wttr.in/?format=%t'",
        "format": "󰖐 {}",
        "interval": 3600
},
    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout"
    }
}
